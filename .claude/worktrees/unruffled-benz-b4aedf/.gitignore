# Never commit local session data or secrets
.DS_Store
*.log
*.jsonl
metrics/
error-log.md
bash-commands.log
mcp-health-cache.json

# Claude Code per-machine permission overrides (project-shared settings.json
# is fine to commit; settings.local.json is per-user and noisy)
.claude/settings.local.json

# MemPalace working files generated by `mempalace init` / `mempalace mine`.
# Per-user palace configuration and noisy auto-extracted entity candidates —
# not project source. If you ever want to commit a curated mempalace.yaml as
# a shared convention, remove it from this ignore list deliberately.
mempalace.yaml
entities.json

# Node
node_modules/
*.tgz

# Editor
.vscode/
.idea/
*.swp
